# Maintainer: Doodcom <a.munro87@icloud.com>
pkgname=pulse-widget-git
pkgver=r5.8f2c5f7
pkgrel=1
pkgdesc="Your PC's vitals as a desktop creature that gets angry when your rig runs hot"
arch=('any')
url="https://github.com/Doodcom/pulse"
license=('MIT')
depends=('electron')
makedepends=('git' 'npm')
source=("git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd pulse
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd pulse
  npm ci --cache "$srcdir/npm-cache"
  npx tsc
}

package() {
  cd pulse

  install -d "$pkgdir/usr/lib/$pkgname"
  cp -r dist index.html assets package.json "$pkgdir/usr/lib/$pkgname/"

  install -d "$pkgdir/usr/bin"
  cat > "$pkgdir/usr/bin/pulse-widget" <<EOF
#!/bin/sh
exec electron /usr/lib/$pkgname "\$@"
EOF
  chmod 755 "$pkgdir/usr/bin/pulse-widget"

  install -d "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/pulse-widget.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Pulse
Comment=$pkgdesc
Exec=pulse-widget
Icon=/usr/lib/$pkgname/assets/icon.png
Terminal=false
Categories=System;Monitor;
StartupWMClass=Pulse
EOF

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
